{
  "name": "helios",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc",
    "prebuild": "node -e \"const p=require('./package.json'); require('fs').writeFileSync('public/version.json',JSON.stringify({version:p.version,project:'helios',updatedAt:new Date().toISOString().split('T')[0]},null,2)+'\\n')\"",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@fontsource/inter": "^5.2.8",
    "@mui/icons-material": "^7.1.0",
    "@mui/material": "^7.1.0",
    "@mui/x-charts": "^9.1.0",
    "@mui/x-data-grid": "^9.1.0",
    "@mui/x-date-pickers": "^9.1.0",
    "@mui/x-tree-view": "^9.1.0",
    "dayjs": "^1.11.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
